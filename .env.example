# Comptoir local development example
# Copy to .env or package-specific .env files as needed.

DATABASE_URL=comptoir.db
PORT=3000
FRONTEND_URL=http://localhost:5173

# Billing/webhooks — use test keys only in local development.
STRIPE_SECRET_KEY=
STRIPE_BASE_PRICE_ID=
STRIPE_SEAT_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# Transactional email/SMS placeholders.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=demo@example.com
OVH_APP_KEY=
OVH_APP_SECRET=
OVH_CONSUMER_KEY=
OVH_SMS_SERVICE_NAME=
OVH_SMS_SENDER=Comptoir

# Solver sidecar; leave empty to use default local fallback where supported.
SOLVER=
CPSAT_SOLVER_URL=http://localhost:8090

# WhatsApp/demo bot local development.
WHATSAPP_URL=http://localhost:3002
DEMO_CHAT_SECRET=dev-demo-secret
LLM_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3

# Meta WhatsApp Cloud API placeholders.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_APP_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_GRAPH_VERSION=v22.0
WEBHOOK_URL=http://localhost:3002/webhook/whatsapp

# OpenAI-compatible hosted model placeholders.
OPENAI_BASE_URL=
OPENAI_MODEL=
OPENAI_API_KEY=
STT_BASE_URL=
STT_MODEL=
STT_LANGUAGE=fr
STT_API_KEY=
