{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@api/*": ["../api/src/*"]
    }
  },
  "include": ["src/**/*.ts", "../api/src/db/schema.ts"]
}
